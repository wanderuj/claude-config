{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr status*)",
      "Bash(gh api*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh label list *)",
      "Bash(plutil -lint *)",
      "mcp__datadog__search_datadog_logs",
      "mcp__datadog__analyze_datadog_logs",
      "mcp__datadog__aggregate_rum_events",
      "mcp__datadog__aggregate_spans",
      "mcp__datadog__get_datadog_trace",
      "mcp__ea1005b7-fa87-487b-adf5-96fce22ee38b__slack_search_users",
      "mcp__ea1005b7-fa87-487b-adf5-96fce22ee38b__slack_search_public_and_private",
      "mcp__Claude_Preview__preview_screenshot"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jbush/.claude/hooks/notify.sh 'Needs your attention' default"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jbush/.claude/hooks/notify.sh 'Task completed' Glass"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "wayfinder@wayfinder": true,
    "swift-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "skipAutoPermissionPrompt": true
}
